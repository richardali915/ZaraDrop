{
  "name": "zaradrop",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*-app",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev:customer-app": "npm --workspace @zaradrop/customer-app run dev",
    "dev:rider-app": "npm --workspace @zaradrop/rider-app run dev",
    "dev:merchant-app": "npm --workspace @zaradrop/merchant-app run dev",
    "dev:admin-app": "npm --workspace @zaradrop/admin-app run dev",
    "build:customer-app": "npm --workspace @zaradrop/customer-app run build",
    "build:rider-app": "npm --workspace @zaradrop/rider-app run build",
    "build:merchant-app": "npm --workspace @zaradrop/merchant-app run build",
    "build:admin-app": "npm --workspace @zaradrop/admin-app run build",
    "build": "npm run build:customer-app && npm run build:rider-app && npm run build:merchant-app && npm run build:admin-app"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.67.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@types/node": "^26.0.1",
    "svelte": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21"
  }
}
