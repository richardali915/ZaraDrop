{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@zaradrop/*": ["packages/*/src"],
      "@zaradrop/customer-app": ["apps/customer-app/src"],
      "@zaradrop/merchant-app": ["apps/merchant-app/src"],
      "@zaradrop/rider-app": ["apps/rider-app/src"],
      "@zaradrop/admin-app": ["apps/admin-app/src"]
    },
    "types": ["node", "svelte"],
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "env.d.ts",
    "apps/**/*",
    "packages/**/*"
  ],
  "exclude": [
    "node_modules",
    "apps/**/.svelte-kit",
    "apps/**/.svelte-kit/**",
    "apps/*/src",
    "apps/*/node_modules",
    "packages/*/src",
    "packages/*/node_modules",
    "supabase/node_modules"
  ]
}
